{
  "agent_name": "LoanPilot Pre-Qualification Agent",
  "agent_type": "extraction_agent",
  "agent_welcome_message": "Hello, am I speaking with {customer_name}? This is Priya calling from {bank_name}.",
  "tasks": [
    {
      "task_type": "conversation",
      "toolchain": {
        "execution": "parallel",
        "pipelines": [
          ["transcriber", "llm", "synthesizer"]
        ]
      },
        "tools_config": {
          "llm_agent": {
            "agent_flow_type": "preprocessed",
            "use_fillers": true,
          "llm_config": {
            "provider": "openai",
            "model": "openai/gpt-4o-mini",
            "max_tokens": 200,
            "family": "openai",
            "temperature": 0.3,
            "base_url": "https://openrouter.ai/api/v1"
          },
          "system_prompt": "Reference snapshot only. The canonical Bolna prompt for this project lives in agent_import.json. If you manually use this file, keep it synchronized with the imported prompt: greet the customer by {customer_name}, introduce yourself from {bank_name}, only then say 'Let me pull up your details' and call fetch_customer_profile, collect loan_type, loan_amount, monthly_income, employment_type, call check_eligibility after collecting all 4, and always call log_lead at the end of the call."
        },
        "synthesizer": {
          "provider": "sarvam",
          "stream": true,
          "provider_config": {
            "voice": "anushka",
            "voice_id": "anushka",
            "model": "bulbul:v2",
            "language": "en-IN"
          },
          "buffer_size": 250,
          "audio_format": "wav"
        },
        "transcriber": {
          "provider": "deepgram",
          "model": "nova-3",
          "encoding": "linear16",
          "language": "en",
          "stream": true,
          "sampling_rate": 16000,
          "endpointing": 180
        }
      },
      "task_config": {
        "hangup_after_silence": 15,
        "hangup_after_LLMCall": true,
        "incremental_delay": 250,
        "number_of_words_for_interruption": 2,
        "backchanneling": true,
        "backchanneling_message_gap": 8,
        "backchanneling_start_delay": 5,
        "voicemail": false,
        "call_cancellation_prompt": "End the call immediately after the closing message if the user says goodbye, thank you, not interested, or if the qualification outcome and next step have already been delivered and no further question remains."
      },
      "tools": [
        {
          "name": "fetch_customer_profile",
          "description": "Fetch existing customer data from the bank CRM using their phone number. Call this at the very start of the conversation to personalize the interaction.",
          "pre_call_message": "Let me pull up your account details.",
          "parameters": {
            "type": "object",
            "properties": {
              "phone": {
                "type": "string",
                "description": "Customer phone number in E.164 format e.g. +919876543210"
              }
            },
            "required": ["phone"]
          },
          "key": "custom_task",
          "value": {
            "method": "POST",
            "param": {
              "tool_name": "fetch_customer_profile",
              "phone": "%(phone)s"
            },
            "url": "https://YOUR_BACKEND_URL/api/webhook/bolna",
            "api_token": "",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        },
        {
          "name": "check_eligibility",
          "description": "Check if the customer pre-qualifies for the requested loan based on their income and loan type. Call this after collecting loan_type, loan_amount, monthly_income, and employment_type.",
          "pre_call_message": "Let me quickly check your eligibility. Just a moment.",
          "parameters": {
            "type": "object",
            "properties": {
              "loan_type": {
                "type": "string",
                "description": "Type of loan: home, personal, business, or auto"
              },
              "loan_amount": {
                "type": "number",
                "description": "Requested loan amount in INR"
              },
              "monthly_income": {
                "type": "number",
                "description": "Customer monthly income in INR"
              },
              "employment_type": {
                "type": "string",
                "description": "salaried, self_employed, or business_owner"
              }
            },
            "required": ["loan_type", "loan_amount", "monthly_income", "employment_type"]
          },
          "key": "custom_task",
          "value": {
            "method": "POST",
            "param": {
              "tool_name": "check_eligibility",
              "loan_type": "%(loan_type)s",
              "loan_amount": "%(loan_amount)f",
              "monthly_income": "%(monthly_income)f",
              "employment_type": "%(employment_type)s"
            },
            "url": "https://YOUR_BACKEND_URL/api/webhook/bolna",
            "api_token": "",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        },
        {
          "name": "log_lead",
          "description": "Save the lead data and conversation outcome to the CRM. ALWAYS call this at the end of every call, even if not interested.",
          "pre_call_message": "Let me save your details.",
          "parameters": {
            "type": "object",
            "properties": {
              "loan_type": {
                "type": "string",
                "description": "Loan type discussed: home, personal, business, or auto"
              },
              "loan_amount": {
                "type": "number",
                "description": "Loan amount in INR if provided"
              },
              "monthly_income": {
                "type": "number",
                "description": "Monthly income in INR if provided"
              },
              "employment_type": {
                "type": "string",
                "description": "Employment type if provided"
              },
              "status": {
                "type": "string",
                "description": "Call outcome: not_interested, interested, pre_qualified, or called"
              },
              "phone": {
                "type": "string",
                "description": "Customer phone number in E.164 format. Always pass the current caller number."
              },
              "call_transcript": {
                "type": "string",
                "description": "Brief summary of what was discussed in the call"
              }
            },
            "required": ["status"]
          },
          "key": "custom_task",
          "value": {
            "method": "POST",
            "param": {
              "tool_name": "log_lead",
              "loan_type": "%(loan_type)s",
              "loan_amount": "%(loan_amount)f",
              "monthly_income": "%(monthly_income)f",
              "employment_type": "%(employment_type)s",
              "status": "%(status)s",
              "phone": "%(phone)s",
              "call_transcript": "%(call_transcript)s"
            },
            "url": "https://YOUR_BACKEND_URL/api/webhook/bolna",
            "api_token": "",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        }
      ]
    }
  ]
}
