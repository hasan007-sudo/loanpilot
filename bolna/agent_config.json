{
  "agent_name": "LoanPilot Pre-Qualification Agent",
  "agent_type": "extraction_agent",
  "agent_welcome_message": "Hello! This is Priya calling from Apex Bank. Do you have 2 minutes? I'd like to share a pre-approved loan offer tailored for you.",
  "webhook_url": "http://localhost:8000/webhook/bolna",
  "tasks": [
    {
      "task_type": "conversation",
      "toolchain": {
        "execution": "parallel",
        "pipelines": [
          ["transcriber", "llm", "synthesizer"]
        ]
      },
      "tools_config": {
        "llm_agent": {
          "agent_flow_type": "preprocessed",
          "use_fillers": true,
          "llm_config": {
            "model": "gpt-4o-mini",
            "max_tokens": 200,
            "family": "openai",
            "temperature": 0.3,
            "base_url": ""
          },
          "system_prompt": "You are Priya, a loan advisor for Apex Bank. Follow the conversation flow and tool call instructions in the attached prompt document exactly."
        },
        "synthesizer": {
          "provider": "elevenlabs",
          "stream": true,
          "provider_config": {
            "voice": "Rachel",
            "model": "eleven_flash_v2_5"
          },
          "buffer_size": 40
        },
        "transcriber": {
          "provider": "deepgram",
          "encoding": "linear16",
          "language": "en-IN",
          "stream": true
        }
      },
      "task_config": {
        "hangup_after_silence": 15,
        "call_cancellation_prompt": "The customer has clearly indicated they are not interested or the conversation has naturally concluded."
      },
      "tools": [
        {
          "name": "fetch_customer_profile",
          "description": "Fetch existing customer data from the bank CRM using their phone number. Call this at the very start of the conversation to personalize the interaction.",
          "url": "http://localhost:8000/webhook/bolna",
          "method": "POST",
          "parameters": {
            "type": "object",
            "properties": {
              "phone": {
                "type": "string",
                "description": "Customer's phone number in E.164 format e.g. +919876543210"
              }
            },
            "required": ["phone"]
          }
        },
        {
          "name": "check_eligibility",
          "description": "Check if the customer pre-qualifies for the requested loan based on their income and loan type. Call this after collecting loan_type, loan_amount, monthly_income, and employment_type.",
          "url": "http://localhost:8000/webhook/bolna",
          "method": "POST",
          "parameters": {
            "type": "object",
            "properties": {
              "phone": {
                "type": "string",
                "description": "Customer phone number"
              },
              "loan_type": {
                "type": "string",
                "enum": ["home", "personal", "business", "auto"],
                "description": "Type of loan the customer is interested in"
              },
              "loan_amount": {
                "type": "number",
                "description": "Requested loan amount in INR"
              },
              "monthly_income": {
                "type": "number",
                "description": "Customer's monthly income in INR"
              },
              "employment_type": {
                "type": "string",
                "enum": ["salaried", "self_employed", "business_owner"],
                "description": "Customer's employment type"
              }
            },
            "required": ["phone", "loan_type", "loan_amount", "monthly_income", "employment_type"]
          }
        },
        {
          "name": "log_lead",
          "description": "Save the lead data and conversation outcome to the bank's CRM. ALWAYS call this at the end of every call, whether the customer is interested or not.",
          "url": "http://localhost:8000/webhook/bolna",
          "method": "POST",
          "parameters": {
            "type": "object",
            "properties": {
              "phone": {
                "type": "string",
                "description": "Customer phone number"
              },
              "loan_type": {
                "type": "string",
                "enum": ["home", "personal", "business", "auto"],
                "description": "Loan type discussed, if any"
              },
              "loan_amount": {
                "type": "number",
                "description": "Requested loan amount in INR, if provided"
              },
              "monthly_income": {
                "type": "number",
                "description": "Monthly income in INR, if provided"
              },
              "employment_type": {
                "type": "string",
                "enum": ["salaried", "self_employed", "business_owner"],
                "description": "Employment type, if provided"
              },
              "status": {
                "type": "string",
                "enum": ["not_interested", "interested", "pre_qualified", "called"],
                "description": "Outcome of the call"
              },
              "call_transcript": {
                "type": "string",
                "description": "A brief plain-text summary of what was discussed in the call"
              }
            },
            "required": ["phone", "status"]
          }
        }
      ]
    }
  ]
}
