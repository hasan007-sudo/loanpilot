{
  "agent_name": "LoanPilot Pre-Qualification Agent",
  "agent_type": "extraction_agent",
  "agent_welcome_message": "Hello! This is Priya calling from Apex Bank. Do you have 2 minutes? I'd like to share a pre-approved loan offer tailored for you.",
  "tasks": [
    {
      "task_type": "conversation",
      "toolchain": {
        "execution": "parallel",
        "pipelines": [
          ["transcriber", "llm", "synthesizer"]
        ]
      },
      "tools_config": {
        "llm_agent": {
          "agent_flow_type": "preprocessed",
          "use_fillers": true,
          "llm_config": {
            "model": "gpt-4o-mini",
            "max_tokens": 200,
            "family": "openai",
            "temperature": 0.3,
            "base_url": ""
          },
          "system_prompt": "You are Priya, a loan advisor for Apex Bank. Follow the conversation flow and tool call instructions in the agent_prompt.md exactly. Collect: loan_type, loan_amount, monthly_income, employment_type. Call check_eligibility after collecting all 4. Always call log_lead at the end of the call."
        },
        "synthesizer": {
          "provider": "elevenlabs",
          "stream": true,
          "provider_config": {
            "voice": "Rachel",
            "model": "eleven_flash_v2_5"
          },
          "buffer_size": 40
        },
        "transcriber": {
          "provider": "deepgram",
          "encoding": "linear16",
          "language": "en-IN",
          "stream": true
        }
      },
      "task_config": {
        "hangup_after_silence": 15,
        "call_cancellation_prompt": "The customer has clearly indicated they are not interested or the conversation has naturally concluded."
      },
      "tools": [
        {
          "name": "fetch_customer_profile",
          "description": "Fetch existing customer data from the bank CRM using their phone number. Call this at the very start of the conversation to personalize the interaction.",
          "pre_call_message": "Let me pull up your account details.",
          "parameters": {
            "type": "object",
            "properties": {
              "phone": {
                "type": "string",
                "description": "Customer phone number in E.164 format e.g. +919876543210"
              }
            },
            "required": ["phone"]
          },
          "key": "custom_task",
          "value": {
            "method": "POST",
            "param": {
              "tool_name": "fetch_customer_profile",
              "phone": "%(phone)s"
            },
            "url": "https://YOUR_BACKEND_URL/webhook/bolna",
            "api_token": "",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        },
        {
          "name": "check_eligibility",
          "description": "Check if the customer pre-qualifies for the requested loan based on their income and loan type. Call this after collecting loan_type, loan_amount, monthly_income, and employment_type.",
          "pre_call_message": "Let me quickly check your eligibility. Just a moment.",
          "parameters": {
            "type": "object",
            "properties": {
              "loan_type": {
                "type": "string",
                "description": "Type of loan: home, personal, business, or auto"
              },
              "loan_amount": {
                "type": "number",
                "description": "Requested loan amount in INR"
              },
              "monthly_income": {
                "type": "number",
                "description": "Customer monthly income in INR"
              },
              "employment_type": {
                "type": "string",
                "description": "salaried, self_employed, or business_owner"
              }
            },
            "required": ["loan_type", "loan_amount", "monthly_income", "employment_type"]
          },
          "key": "custom_task",
          "value": {
            "method": "POST",
            "param": {
              "tool_name": "check_eligibility",
              "loan_type": "%(loan_type)s",
              "loan_amount": "%(loan_amount)f",
              "monthly_income": "%(monthly_income)f",
              "employment_type": "%(employment_type)s"
            },
            "url": "https://YOUR_BACKEND_URL/webhook/bolna",
            "api_token": "",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        },
        {
          "name": "log_lead",
          "description": "Save the lead data and conversation outcome to the CRM. ALWAYS call this at the end of every call, even if not interested.",
          "pre_call_message": "Let me save your details.",
          "parameters": {
            "type": "object",
            "properties": {
              "loan_type": {
                "type": "string",
                "description": "Loan type discussed: home, personal, business, or auto"
              },
              "loan_amount": {
                "type": "number",
                "description": "Loan amount in INR if provided"
              },
              "monthly_income": {
                "type": "number",
                "description": "Monthly income in INR if provided"
              },
              "employment_type": {
                "type": "string",
                "description": "Employment type if provided"
              },
              "status": {
                "type": "string",
                "description": "Call outcome: not_interested, interested, pre_qualified, or called"
              },
              "call_transcript": {
                "type": "string",
                "description": "Brief summary of what was discussed in the call"
              }
            },
            "required": ["status"]
          },
          "key": "custom_task",
          "value": {
            "method": "POST",
            "param": {
              "tool_name": "log_lead",
              "loan_type": "%(loan_type)s",
              "loan_amount": "%(loan_amount)f",
              "monthly_income": "%(monthly_income)f",
              "employment_type": "%(employment_type)s",
              "status": "%(status)s",
              "call_transcript": "%(call_transcript)s"
            },
            "url": "https://YOUR_BACKEND_URL/webhook/bolna",
            "api_token": "",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        }
      ]
    }
  ]
}
