# --- Database (Neon Postgres) ---
# Pooled connection (port 6543, ?pgbouncer=true) — used by the app at runtime.
# Required. Format: postgresql://USER:PASSWORD@HOST-pooler/DBNAME?sslmode=require&pgbouncer=true
DATABASE_URL=

# Direct connection (port 5432) — used only by `prisma migrate`.
# Required for migrations. Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DIRECT_URL=

# --- Bolna (voice agent) ---
# Optional. Without these the campaigns endpoints save leads but skip Bolna calls.
BOLNA_API_KEY=
BOLNA_AGENT_ID=
BOLNA_FROM_NUMBER=

# --- OpenRouter (call summary generation) ---
# Optional. Without OPENROUTER_API_KEY the webhook returns a mock summary.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-preview
